# Binaries for programs and plugins.
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`.
*.test

# Output of the go coverage tool, specifically when used with LiteIDE.
*.out

# Dependency directories (Safe to ignore as we use go modules).
vendor/

# Environment Variables (CRITICAL: Never push secrets to GitHub).
.env
.env.local
.env.*

# Visual Studio Code / IDEs.
.vscode/
.idea/
*.swp
*.swo

# OS specific files.
.DS_Store
Thumbs.db

# Uploaded media or temp files (if stored locally during dev).
/uploads
/tmp

# Ignore local draft files.
Draft*.txt